{
  "name": "least-privlege-bird",
  "version": "1.0.0",
  "description": "Flappy bird wrapped in AWS IAM bureaucracy satire",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=dist/bundle.js --format=iife --sourcemap --servedir=. --watch",
    "build": "esbuild src/main.ts --bundle --outfile=dist/bundle.js --format=iife --sourcemap --minify",
    "test": "esbuild scripts/test-replay.ts --bundle --platform=node --format=esm --outfile=dist/test-replay.mjs && node dist/test-replay.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
